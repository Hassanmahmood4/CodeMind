# CodeMind Frontend – copy to .env and fill in
# cp .env.example .env

# Clerk: get from dashboard.clerk.com → API Keys. Use the copy icon next to "Publishable key"
# (not Quick copy). Add http://localhost:5173 in Clerk Dashboard → Configure → Domains if needed.
VITE_CLERK_PUBLISHABLE_KEY=

# Backend API base URL (default for local dev)
VITE_API_URL=http://localhost:5000
